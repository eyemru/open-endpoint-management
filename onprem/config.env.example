# On-prem deployment config. Copy to `config.env` and fill in, then run the install
# scripts AS ROOT (sudo) directly on each Ubuntu 22.04 / Debian 12 server.
# Gitignored (matches *.env). Never commit real secrets.

# =========================================================================
# TLS strategy — the key on-prem decision
#   letsencrypt : server is internet-reachable on ports 80/443 (HTTP-01).
#   byo         : bring your own cert (corporate/internal CA). Set CERT_FULLCHAIN/PRIVKEY.
#   selfsigned  : lab only. Agents validate TLS, so you must trust the generated CA on
#                 every endpoint (or the agents won't connect). Not for production.
# =========================================================================
CERT_MODE="letsencrypt"
LE_EMAIL="you@example.com"           # letsencrypt only
CERT_FULLCHAIN=""                    # byo only: path to your fullchain.pem on this server
CERT_PRIVKEY=""                      # byo only: path to your privkey.pem on this server

# =========================================================================
# Tactical RMM  (run ./install-trmm.sh on the TRMM server)
# Needs 3 hostnames that resolve to THIS server: api./rmm./mesh.<TRMM_ROOT>
# =========================================================================
TRMM_ROOT="example.com"              # base domain; installer uses api./rmm./mesh.<root>
TRMM_ADMIN_USER="trmmadmin"
TRMM_ADMIN_PASS="CHANGE-ME-strong"   # avoid single quotes (')
TRMM_INSTALL_USER="tactical"         # non-root user to run the installer (created if missing)

# =========================================================================
# FleetDM  (run ./install-fleet.sh on the Fleet server)
# FLEET_HOSTNAME must resolve to THIS server.
# =========================================================================
FLEET_HOSTNAME="fleet.example.com"
FLEET_HTTPS_PORT="443"               # use e.g. 8443 if co-hosting on the SAME box as TRMM
FLEET_ORG="MyOrg"
FLEET_ADMIN_EMAIL="you@example.com"
FLEET_ADMIN_PASS="CHANGE-ME-min-12"  # >= 12 chars; avoid single quotes (')
