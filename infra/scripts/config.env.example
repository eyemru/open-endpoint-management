# Copy this file to `config.env` and fill in your values.
# `config.env` holds secrets and is gitignored (matches *.env). Never commit it.

# --- AWS ---
AWS_REGION="us-west-2"
PROJECT="epm-poc"
INSTANCE_TYPE="t3.medium"          # >=4GB RAM recommended for Tactical RMM

# --- DuckDNS (free dynamic DNS) ---
DUCKDNS_SUBDOMAIN="nbcepm"          # the label only (before .duckdns.org)
DUCKDNS_TOKEN="REPLACE_ME"          # from https://www.duckdns.org (account page)
TRMM_ROOT="nbcepm.duckdns.org"      # = DUCKDNS_SUBDOMAIN + .duckdns.org

# --- Let's Encrypt + Tactical RMM admin ---
LE_EMAIL="you@example.com"          # Let's Encrypt registration email
TRMM_ADMIN_USER="nbcadmin"
TRMM_ADMIN_PASS="REPLACE_ME"        # strong; AVOID single quotes (') in the value

# --- Fleet (compliance plane, separate instance) ---
# Leave FLEET_HOSTNAME empty to auto-use <fleet-eip>.sslip.io (DuckDNS is usually 5/5).
FLEET_HOSTNAME=""
FLEET_ORG="Northbridge"
FLEET_ADMIN_EMAIL="you@example.com"
FLEET_ADMIN_PASS="REPLACE_ME"        # >= 12 chars (Fleet enforces complexity)

# --- Optional ---
# Public IP (CIDR) allowed to SSH. Leave empty to auto-detect this machine's IP.
ADMIN_CIDR=""
